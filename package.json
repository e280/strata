		"typescript": "^7.0.2"
	},
	"keywords": [
		"state",
		"state management"
	],
	"homepage": "https://github.com/e280/strata#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/e280/strata.git"
	},
	"bugs": {
		"url": "https://github.com/e280/strata/issues"
	}
